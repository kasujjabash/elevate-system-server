# Environment Configuration for Elevate Academy
APP_ENVIRONMENT=local

# Database Configuration
DATABASE_URL="postgresql://username:password@localhost:5432/elevate-academy-db"
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=username
DB_PASSWORD=password
DB_DATABASE=elevate-academy-db
DB_SYNCHRONIZE=false
DB_LOGGING=false

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key
JWT_EXPIRY=24h

# Application Configuration
PORT=3000

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-email-password

# Sentry Configuration (Production)
REACT_APP_SENTRY_DSN=your-sentry-dsn

# Google Services (Optional)
GOOGLE_PRIVATE_KEY=your-google-private-key
GOOGLE_CLIENT_EMAIL=your-google-client-email

# File Upload Configuration
MAX_FILE_SIZE=10485760  # 10MB in bytes
UPLOAD_DESTINATION=./uploads