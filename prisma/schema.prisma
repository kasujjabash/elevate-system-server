generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "darwin", "darwin-arm64"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model address {
  id             Int                   @id @default(autoincrement())
  category       address_category_enum @default(Home)
  isPrimary      Boolean
  country        String                @db.VarChar
  district       String                @db.VarChar
  freeForm       String?               @db.VarChar
  latitude       Float?
  longitude      Float?
  geoCoordinates Unsupported("point")?
  placeId        String?               @db.VarChar
  contactId      Int
  contact        contact               @relation(fields: [contactId], references: [id])
}

model contact {
  id             Int                   @id @default(autoincrement())
  category       contact_category_enum @default(Person)
  address        address[]
  email          email[]
  phone          phone[]
  identification identification[]
  person         person?
  student        student?
  instructor     instructor?
  user           user?
}

model email {
  id        Int                 @id @default(autoincrement())
  category  email_category_enum @default(Personal)
  value     String              @db.VarChar
  isPrimary Boolean             @default(false)
  contactId Int
  contact   contact             @relation(fields: [contactId], references: [id])
}

model phone {
  id        Int                 @id @default(autoincrement())
  category  phone_category_enum @default(Mobile)
  value     String              @db.VarChar
  isPrimary Boolean
  contactId Int
  contact   contact             @relation(fields: [contactId], references: [id])
}

model identification {
  id             Int                          @id @default(autoincrement())
  value          String                       @db.VarChar
  cardNumber     String                       @db.VarChar
  issuingCountry String                       @db.VarChar
  startDate      DateTime                     @db.Timestamp(6)
  expiryDate     DateTime                     @db.Timestamp(6)
  category       identification_category_enum @default(Nin)
  isPrimary      Boolean
  contactId      Int
  contact        contact                      @relation(fields: [contactId], references: [id])
}

model person {
  id          Int                @id @default(autoincrement())
  firstName   String             @db.VarChar(40)
  lastName    String             @db.VarChar(40)
  middleName  String?            @db.VarChar(40)
  gender      person_gender_enum
  avatar      String?            @db.VarChar
  dateOfBirth DateTime?          @db.Date
  contactId   Int                @unique
  contact     contact            @relation(fields: [contactId], references: [id])
}

model hub {
  id                 Int                  @id @default(autoincrement())
  name               String               @db.VarChar(100)
  code               String               @unique @db.VarChar(20)
  description        String?              @db.VarChar(500)
  location           String               @db.VarChar(100)
  address            String?              @db.VarChar(500)
  isActive           Boolean              @default(true)
  // Hub manager
  managerName        String?              @db.VarChar(100)
  managerPhone       String?              @db.VarChar(30)
  managerEmail       String?              @db.VarChar(100)
  // Resources
  computers          Int?                 @default(0)
  projectors         Int?                 @default(0)
  capacity           Int?
  notes              String?              @db.Text
  students           student[]
  courses            course[]
  instructors        instructor[]
  attendanceSessions attendance_session[]
  timetableSessions  timetable_session[]
  managers           user[]
  workshops          workshop[]
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
}

model skill_category {
  id          String   @id @db.VarChar(40)
  name        String   @db.VarChar(100)
  description String?  @db.VarChar(500)
  courses     course[]
}

model course {
  id                 Int                  @id @default(autoincrement())
  title              String               @db.VarChar(200)
  description        String               @db.VarChar(1000)
  duration           String?              @db.VarChar(50)
  isActive           Boolean              @default(true)
  isEnrollable       Boolean              @default(true)
  maxStudents        Int?
  hubId              Int?
  instructorId       Int?
  skillCategoryId    String?              @db.VarChar(40)
  hub                hub?                 @relation(fields: [hubId], references: [id])
  instructor         instructor?          @relation(fields: [instructorId], references: [id])
  skillCategory      skill_category?      @relation(fields: [skillCategoryId], references: [id])
  enrollments        enrollment[]
  study_resources    study_resource[]
  assignments        assignment[]
  modules            course_module[]
  attendanceSessions attendance_session[]
  timetableSessions  timetable_session[]
  chatRooms          chat_room[]
  workshops          workshop[]
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
}

model student {
  id                Int                 @id @default(autoincrement())
  studentId         String              @unique @db.VarChar(20)
  contactId         Int                 @unique
  hubId             Int
  status            student_status_enum @default(Active)
  enrolledAt        DateTime            @default(now())
  contact           contact             @relation(fields: [contactId], references: [id])
  hub               hub                 @relation(fields: [hubId], references: [id])
  enrollments       enrollment[]
  submissions       submission[]
  contentProgress   content_progress[]
  attendanceRecords attendance_record[]
  requests          student_request[]
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
}

model instructor {
  id             Int      @id @default(autoincrement())
  employeeId     String   @unique @db.VarChar(20)
  contactId      Int      @unique
  hubId          Int
  specialization String?  @db.VarChar(200)
  isActive       Boolean  @default(true)
  contact        contact  @relation(fields: [contactId], references: [id])
  hub            hub      @relation(fields: [hubId], references: [id])
  courses        course[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model enrollment {
  id          Int                    @id @default(autoincrement())
  studentId   Int
  courseId    Int
  status      enrollment_status_enum @default(Enrolled)
  enrolledAt  DateTime               @default(now())
  completedAt DateTime?
  progress    Float                  @default(0)
  student     student                @relation(fields: [studentId], references: [id])
  course      course                 @relation(fields: [courseId], references: [id])

  @@unique([studentId, courseId])
}

model study_resource {
  id          Int                      @id @default(autoincrement())
  title       String                   @db.VarChar(200)
  description String?                  @db.VarChar(1000)
  type        study_resource_type_enum @default(Document)
  url         String?                  @db.VarChar(500)
  filePath    String?                  @db.VarChar(500)
  courseId    Int
  isPublic    Boolean                  @default(false)
  course      course                   @relation(fields: [courseId], references: [id])
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
}

model assignment {
  id          Int          @id @default(autoincrement())
  title       String       @db.VarChar(200)
  description String       @db.VarChar(1000)
  dueDate     DateTime?
  maxScore    Int?         @default(100)
  weekNumber  Int?
  isMilestone Boolean      @default(false)
  courseId    Int
  isActive    Boolean      @default(true)
  course      course       @relation(fields: [courseId], references: [id])
  submissions submission[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model course_module {
  id          Int              @id @default(autoincrement())
  title       String           @db.VarChar(200)
  description String?          @db.VarChar(1000)
  weekNumber  Int              @default(1)
  order       Int              @default(0)
  isPublished Boolean          @default(true)
  courseId    Int
  course      course           @relation(fields: [courseId], references: [id])
  contents    module_content[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model module_content {
  id          Int                      @id @default(autoincrement())
  title       String                   @db.VarChar(200)
  body        String?                  @db.Text
  videoUrl    String?                  @db.VarChar(500)
  type        module_content_type_enum @default(Lesson)
  order       Int                      @default(0)
  durationMin Int?
  isPublished Boolean                  @default(true)
  moduleId    Int
  module      course_module            @relation(fields: [moduleId], references: [id])
  progress    content_progress[]
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
}

model content_progress {
  id          Int            @id @default(autoincrement())
  studentId   Int
  contentId   Int
  completedAt DateTime       @default(now())
  student     student        @relation(fields: [studentId], references: [id])
  content     module_content @relation(fields: [contentId], references: [id])

  @@unique([studentId, contentId])
}

model submission {
  id           Int                    @id @default(autoincrement())
  studentId    Int
  assignmentId Int
  content      String?                @db.Text
  filePath     String?                @db.VarChar(500)
  score        Int?
  feedback     String?                @db.Text
  status       submission_status_enum @default(Submitted)
  submittedAt  DateTime               @default(now())
  gradedAt     DateTime?
  student      student                @relation(fields: [studentId], references: [id])
  assignment   assignment             @relation(fields: [assignmentId], references: [id])

  @@unique([studentId, assignmentId])
}

model user {
  id        Int     @id @default(autoincrement())
  username  String  @unique @db.VarChar(40)
  password  String  @db.VarChar(100)
  contactId Int     @unique
  roles     String?
  isActive  Boolean
  hubId     Int?
  contact   contact @relation(fields: [contactId], references: [id])
  hub       hub?    @relation(fields: [hubId], references: [id])
}

model announcement {
  id        Int       @id @default(autoincrement())
  title     String    @db.VarChar(200)
  body      String    @db.Text
  type      String    @default("info") // info | warning | event | success
  pinned    Boolean   @default(false)
  isActive  Boolean   @default(true)
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy Int?
}

model attendance_session {
  id        Int                 @id @default(autoincrement())
  token     String              @unique @db.VarChar(64)
  shortCode String              @unique @db.VarChar(8)
  courseId  Int?
  hubId     Int?
  label     String?             @db.VarChar(200)
  expiresAt DateTime
  isActive  Boolean             @default(true)
  createdBy Int?
  createdAt DateTime            @default(now())
  records   attendance_record[]
  course    course?             @relation(fields: [courseId], references: [id])
  hub       hub?                @relation(fields: [hubId], references: [id])
}

model attendance_record {
  id          Int                @id @default(autoincrement())
  sessionId   Int
  studentId   Int
  checkedInAt DateTime           @default(now())
  method      String             @default("QR") // QR | Manual
  session     attendance_session @relation(fields: [sessionId], references: [id])
  student     student            @relation(fields: [studentId], references: [id])

  @@unique([sessionId, studentId])
}

model calendar_event {
  id          Int       @id @default(autoincrement())
  title       String    @db.VarChar(200)
  description String?   @db.Text
  eventDate   DateTime
  endDate     DateTime?
  location    String?   @db.VarChar(300)
  type        String    @default("general") // general | class | holiday | milestone | deadline
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  createdBy   Int?
}

enum address_category_enum {
  Work
  Home
  Other
}

enum contact_category_enum {
  Person
}

enum email_category_enum {
  Work
  Personal
  School
  Other
}

enum phone_category_enum {
  Mobile
  Office
  Home
  Other
}

enum identification_category_enum {
  Nin
  Passport
  DrivingPermit
  StudentId
  Other
}

enum person_gender_enum {
  Male
  Female
}

enum student_status_enum {
  Active
  Inactive
  Graduated
  Suspended
}

enum enrollment_status_enum {
  Pending
  Enrolled
  InProgress
  Completed
  Dropped
}

enum study_resource_type_enum {
  Document
  Video
  Audio
  Image
  Link
  Software
}

enum submission_status_enum {
  Submitted
  Graded
  Returned
}

enum module_content_type_enum {
  Lesson
  Video
  Quiz
  Assignment
  Resource
}

model student_request {
  id        Int                 @id @default(autoincrement())
  studentId Int
  subject   String              @db.VarChar(300)
  body      String              @db.Text
  type      String              @default("inquiry")
  status    request_status_enum @default(Open)
  student   student             @relation(fields: [studentId], references: [id])
  messages  request_message[]
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
}

model request_message {
  id         Int             @id @default(autoincrement())
  requestId  Int
  body       String          @db.Text
  senderType String          @default("student")
  senderId   Int?
  request    student_request @relation(fields: [requestId], references: [id])
  createdAt  DateTime        @default(now())
}

enum request_status_enum {
  Open
  InProgress
  Resolved
  Closed
}

model timetable_session {
  id             Int      @id @default(autoincrement())
  courseId       Int
  hubId          Int?
  instructorName String?  @db.VarChar(200)
  dayOfWeek      Int
  startTime      String   @db.VarChar(5)
  endTime        String   @db.VarChar(5)
  room           String?  @db.VarChar(100)
  meetLink       String?  @db.VarChar(500)
  course         course   @relation(fields: [courseId], references: [id])
  hub            hub?     @relation(fields: [hubId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model chat_room {
  id        Int            @id @default(autoincrement())
  type      String         @db.VarChar(10)
  title     String?        @db.VarChar(200)
  courseId  Int?
  course    course?        @relation(fields: [courseId], references: [id])
  members   chat_member[]
  messages  chat_message[]
  createdAt DateTime       @default(now())
}

model chat_member {
  id        Int       @id @default(autoincrement())
  roomId    Int
  userId    Int
  room      chat_room @relation(fields: [roomId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@unique([roomId, userId])
}

model chat_message {
  id        Int       @id @default(autoincrement())
  roomId    Int
  senderId  Int
  content   String
  room      chat_room @relation(fields: [roomId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
}

model workshop {
  id          Int                @id @default(autoincrement())
  title       String             @db.VarChar(200)
  description String?            @db.VarChar(1000)
  type        workshop_type_enum @default(Workshop)
  url         String?            @db.VarChar(500)
  courseId    Int?
  hubId       Int?
  isActive    Boolean            @default(true)
  course      course?            @relation(fields: [courseId], references: [id])
  hub         hub?               @relation(fields: [hubId], references: [id])
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

enum workshop_type_enum {
  Workshop
  Podcast
}
